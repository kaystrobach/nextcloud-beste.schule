{
    "name": "kaystrobach/beste_schule",
    "description": "Synchronize grades and journal from beste.schule",
    "license": "agpl",
    "authors": [
        {
            "name": "beste.schule Nextcloud Integration"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "nextcloud/ocp": "dev-master",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "nextcloud/openapi-extractor": "^1.8",
        "phpstan/phpstan": "^2.2",
        "nextcloud/coding-standard": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "OCA\\BesteSchule\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\BesteSchule\\Tests\\": "tests/",
            "OCP\\": "vendor/nextcloud/ocp/OCP/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "scripts": {
        "generate-spec": "@php vendor/bin/openapi-extractor generate -i lib/",
        "test": "@php vendor/bin/phpunit",
        "lint": "@php vendor/bin/phpcs --standard=phpcs.xml"
    }
}

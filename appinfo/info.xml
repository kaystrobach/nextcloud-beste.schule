<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>beste_schule</id>
    <name>beste.schule</name>
    <summary>Synchronize grades and journal from beste.schule</summary>
    <description><![CDATA[
        Connect your beste.schule account to Nextcloud.
        - Syncs grades (Noten) and final grades (Endnoten) from beste.schule
        - Creates calendar events from the school journal (Klassenbuch)
        - Background sync keeps everything up to date automatically
        - Admin view to manage per-user account mappings
    ]]></description>
    <version>1.0.0</version>
    <licence>agpl</licence>
    <author>beste.schule Nextcloud Integration</author>
    <namespace>BesteSchule</namespace>
    <category>integration</category>
    <category>organization</category>
    <category>office</category>
    <bugs>https://github.com/example/beste-schule-nextcloud/issues</bugs>
    <dependencies>
        <php min-version="8.1"/>
        <nextcloud min-version="27" max-version="34"/>
    </dependencies>
    <background-jobs>
        <job>OCA\BesteSchule\BackgroundJob\SyncJob</job>
    </background-jobs>
    <commands>
        <command>OCA\BesteSchule\Command\JournalCommand</command>
        <command>OCA\BesteSchule\Command\SyncCommand</command>
    </commands>
    <settings>
        <admin>OCA\BesteSchule\Settings\AdminSettings</admin>
        <personal>OCA\BesteSchule\Settings\PersonalSettings</personal>
    </settings>
    <navigations>
        <navigation>
            <name>beste.schule</name>
            <route>beste_schule.grades.index</route>
            <icon>app.svg</icon>
        </navigation>
    </navigations>
</info>
